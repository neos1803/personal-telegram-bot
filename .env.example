# Telegram Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_USERNAME=
TELEGRAM_FETCH_LIMIT=25
TELEGRAM_POLL_CRON=* * * * *
TELEGRAM_PROCESS_CRON=* * * * *
TELEGRAM_PROACTIVE_CRON=*/30 * * * *
TELEGRAM_PROACTIVE_POST_BATCH_COOLDOWN_MS=60000
TELEGRAM_BATCH_DELAY_MS=120000
TELEGRAM_CHUNK_DELAY_MS=800
TELEGRAM_VOICE_REPLY_CHANCE=0.2
DEBUG_LOGS=false

# GitLab Configuration
GITLAB_TOKEN=
GITLAB_USERNAME=
GITLAB_HOST=
GITLAB_LOOKBACK_DAYS=1

# OpenRouter Configuration
OPENROUTER_API_KEY=
OPENROUTER_TTS_MODEL=openai/gpt-4o-mini-tts-2025-12-15
OPENROUTER_TTS_VOICE=Leda
OPENROUTER_TTS_RESPONSE_FORMAT=pcm
OPENROUTER_TTS_SPEED=1

# Azure Blob Storage Configuration
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=personal-experiment

# Runtime Configuration
MESSAGE_RETENTION_DAYS=3
RUNTIME_DATA_DIR=.runtime
